# Copie para .env no servidor/backend quando houver API.
# Nunca suba .env real para o GitHub.

APP_PUBLIC_URL=https://seudominio.com.br

# Banco de dados futuro
DATABASE_URL=postgresql://usuario:senha@host:5432/regis_imobiliaria

# Storage/nuvem futuro
STORAGE_PROVIDER=supabase
STORAGE_ENDPOINT=https://seuprojeto.supabase.co/storage/v1
STORAGE_BUCKET=regis-arquivos
STORAGE_PUBLIC_BASE_URL=https://seuprojeto.supabase.co/storage/v1/object/public/regis-arquivos

# Google Maps
GOOGLE_MAPS_API_KEY=coloque_a_chave_aqui

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=coloque_o_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=coloque_o_business_account_id
WHATSAPP_ACCESS_TOKEN=coloque_o_token_no_backend
WHATSAPP_WEBHOOK_VERIFY_TOKEN=crie_um_token_de_verificacao
